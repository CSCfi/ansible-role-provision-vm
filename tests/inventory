testservers:
    children:
            centos8_cloud_init_image:
            centos8_ethernets_image:
            centos8_kickstart_install:
            alma9_ethernets_image:
            alma9_kickstart_install:
vars:
    install_extra_packages:
        - qemu-kvm
        - qemu-img
        - libvirt
        - python3-libvirt
        - libguestfs-tools
        - virt-install
        - virt-top  

centos8_cloud_init_image:
    hosts:
        server1:
    vars:
        ansible_python_interpreter: auto_legacy
        os_variant: centos8
        guest_type: image
        cloud_init_networks:
        -   interface: eth0
            address: "192.168.1.50"
            netmask: "255.255.255.0"
        install_extra_packages:
            - qemu-kvm
            - qemu-img
            - libvirt
            - python3-libvirt
            - libguestfs-tools
            - virt-install
            - virt-top  

centos8_ethernets_image:
    hosts:
        server2:
    vars:
        os_variant: centos8
        install_extra_packages:
        - libguestfs-tools
        - libvirt
        - openssh-server
        - python3-libvirt
        - qemu-kvm
        - qemu-img
        - virt-install
        - virt-top

centos8_kickstart_install:
    hosts:
        server3:
    vars:
        os_variant: centos8
        install_extra_packages:
        - libguestfs-tools
        - libvirt
        - openssh-server
        - python3-libvirt
        - qemu-kvm
        - qemu-img
        - virt-install
        - virt-top

alma9_ethernets_image:
    hosts:
        server4:
    vars:
        ansible_python_interpreter: auto
        os_variant: almalinux9
        guest_type: image
        ethernets:
        -   name: eth0
            address6: "2001:db8::1/64"
            gateway6: "2001:db8::1"
            nameservers: "8.8.8.8 + 2001:4860:4860::8888"
            address4: "192.168.1.50/24"
            gateway4: "192.168.1.1"

alma9_kickstart_install:
    hosts:
        server5:
    vars:
        os_variant: almalinux9
